# ===========================================
# VARIÁVEIS DE AMBIENTE — Procura-Vaga
# ===========================================
# Copie para .env.local e preencha. NUNCA commite o .env.local.

# --- Banco: Neon Postgres (via Vercel Marketplace) ---
# Vercel Dashboard → Storage → Neon → Create → copie a "Pooled connection string"
DATABASE_URL=postgresql://USER:PASS@HOST/neondb?sslmode=require

# --- Auth (Auth.js / NextAuth) ---
AUTH_SECRET=cole-o-secret-gerado-aqui
AUTH_URL=http://localhost:3000
ALLOWED_EMAIL=r.lopes.marques01@gmail.com   # destino do digest + 2ª barreira (login é por usuário/senha)

# --- Primeiro usuário / criar usuário (pnpm seed:user) — login usuário/senha, SEM signup ---
# Defina SEED_PASSWORD TEMPORARIAMENTE só para rodar "pnpm seed:user", depois REMOVA a linha.
# SEED_USERNAME=procuravaga
# SEED_EMAIL=                               # se vazio, usa ALLOWED_EMAIL (manter igual p/ o digest achar o user)
# SEED_PASSWORD=

# --- Email: Resend (digest diário; o login NÃO usa mais e-mail) ---
# resend.com → API Keys → Create
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=onboarding@resend.dev            # ou um remetente do seu domínio verificado

# --- Fontes de vaga (APIs grátis) ---
RAPIDAPI_KEY=xxxxxxxx                        # JSearch (Google for Jobs) via rapidapi.com
ADZUNA_APP_ID=xxxxxxxx                       # developer.adzuna.com
ADZUNA_APP_KEY=xxxxxxxx
JOOBLE_API_KEY=xxxxxxxx                       # jooble.org/api/about

# --- LLM do currículo (escolha UM provider) ---
LLM_PROVIDER=gemini                          # gemini (grátis) | anthropic (pago) | groq (grátis)
GEMINI_API_KEY=xxxxxxxx                       # aistudio.google.com/app/apikey (free tier)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx             # console.anthropic.com (sem free tier, ~centavos/CV)
GROQ_API_KEY=xxxxxxxx                         # console.groq.com (free, Llama)

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=
